{
  "name": "updater",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@8.15.9",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "dev:api": "pnpm --filter @updater/api start:dev",
    "dev:admin": "pnpm --filter @updater/admin-zone dev",
    "dev:component": "pnpm --filter @updater/component build --watch"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
